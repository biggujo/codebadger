# Configuration is now centralized in src/defaults.py
# Override defaults by modifying config.yaml or setting environment variables
#
# For more control, edit config.yaml directly or set these env vars:
# - MCP_HOST, MCP_PORT, MCP_LOG_LEVEL
# - JOERN_BINARY_PATH, JOERN_MEMORY_LIMIT, JOERN_JAVA_OPTS
# - CPG_GENERATION_TIMEOUT, MAX_REPO_SIZE_MB
# - QUERY_TIMEOUT, QUERY_CACHE_ENABLED, QUERY_CACHE_TTL
# - WORKSPACE_ROOT, CLEANUP_ON_SHUTDOWN

# Docker Configuration
# Note: Joern is built locally as codebadger-joern-server:latest via docker-compose
DOCKER_HOST=unix:///var/run/docker.sock

# GitHub (optional)
GITHUB_TOKEN=

